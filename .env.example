# =============================================================================
# AXIS — environment configuration template.
#
# Copy to `.env` (gitignored). Every variable AXIS reads at runtime is listed
# here with a documented purpose and a safe default where one exists.
#
#   cp .env.example .env
#   docker compose up -d db redis
# =============================================================================

# --- Runtime ------------------------------------------------------------------
# `development` | `staging` | `production`. Gates strict-mode behavior, log
# formatters, and docs/openapi exposure.
AXIS_ENV=development
AXIS_LOG_LEVEL=INFO
AXIS_HOST=0.0.0.0
AXIS_PORT=8000

# --- Database -----------------------------------------------------------------
# SQLAlchemy DSN used by both API and worker. asyncpg driver is mandatory.
AXIS_DB_DSN=postgresql+asyncpg://axis:axis@localhost:5432/axis
# Pool sizing — set per process; worker uses smaller pool by default.
AXIS_DB_POOL_SIZE=10
AXIS_DB_MAX_OVERFLOW=5

# --- Redis (cache + ARQ broker + slowapi backend) -----------------------------
AXIS_REDIS_URL=redis://localhost:6379/0

# --- Auth ---------------------------------------------------------------------
# Access tokens are JWT RS256 in production; HS256 with this secret is allowed
# only in `development`. Generate a real secret:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
AXIS_JWT_SECRET=__replace_me_in_real_envs__
AXIS_JWT_ALG=HS256
AXIS_ACCESS_TOKEN_TTL_SECONDS=900            # 15 min
AXIS_REFRESH_TOKEN_TTL_SECONDS=2592000       # 30 days
# Issuer and audience claims; pin per environment.
AXIS_JWT_ISSUER=axis.local
AXIS_JWT_AUDIENCE=axis-api

# --- Anthropic (LLM extraction) -----------------------------------------------
ANTHROPIC_API_KEY=__replace_me__
AXIS_EXTRACTION_MODEL=claude-opus-4-7
# Confidence routing thresholds (see ARCHITECTURE.md §5.1).
AXIS_EXTRACTION_PERSIST_THRESHOLD=0.80
AXIS_EXTRACTION_REVIEW_THRESHOLD=0.50

# --- Ingestion resilience -----------------------------------------------------
AXIS_INGEST_MAX_ATTEMPTS=5
AXIS_INGEST_BACKOFF_BASE_SECONDS=2
AXIS_INGEST_BACKOFF_MAX_SECONDS=60
AXIS_BREAKER_FAILS_TO_OPEN=5
AXIS_BREAKER_WINDOW_SECONDS=60
AXIS_BREAKER_OPEN_SECONDS=30

# --- Observability ------------------------------------------------------------
# `none` disables OTel export entirely; `otlp` ships to AXIS_OTEL_ENDPOINT.
AXIS_OTEL_EXPORTER=none
AXIS_OTEL_ENDPOINT=http://localhost:4317
AXIS_OTEL_SERVICE_NAME=axis-api

# --- Rate limiting (slowapi) --------------------------------------------------
AXIS_RATELIMIT_DEFAULT=100/minute
AXIS_RATELIMIT_AUTH=10/minute

# --- Partner API keys ---------------------------------------------------------
# Hash algorithm + visible-prefix length used when minting partner keys.
AXIS_PARTNER_KEY_PREFIX_LEN=8

# --- Docker compose overrides (optional) --------------------------------------
# POSTGRES_USER=axis
# POSTGRES_PASSWORD=axis
# POSTGRES_DB=axis
# POSTGRES_PORT=5432
# REDIS_PORT=6379
